# =============================================================
# Flowerbed — .env.example
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://flowerbed_user:your_password@localhost:5432/flowerbed_db"

# ── Better Auth ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate_a_32_char_secret_here"
BETTER_AUTH_URL="http://localhost:3000"

# ── App URL (client-side) ─────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email (Resend) ────────────────────────────────────────────
# Get your API key at: https://resend.com
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="no-reply@yourdomain.com"

# ── Background Jobs (Trigger.dev) ─────────────────────────────
# Get your key at: https://cloud.trigger.dev
TRIGGER_SECRET_KEY="your_trigger_secret_key"

# ── Error Monitoring (Sentry) ─────────────────────────────────
# Get your DSN at: https://sentry.io (or self-hosted)
SENTRY_DSN="https://your_sentry_dsn@sentry.io/your_project_id"

# ── Analytics (Plausible) ─────────────────────────────────────
# Set to your domain (e.g., "yourdomain.com")
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="yourdomain.com"
