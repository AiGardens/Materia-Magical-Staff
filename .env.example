# =============================================================
# Materia Magical Staff — .env.example
# Copy this file to .env and fill in your values.
# DO NOT commit .env or .env.local to version control.
# =============================================================

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Docker Compose overrides DATABASE_URL automatically. This value is
# for local development without Docker (e.g. a local Postgres instance).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://materia_user:your_password@localhost:5432/materia_db"
POSTGRES_PASSWORD="your_postgres_password"

# ── Better Auth ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate_a_32_char_secret_here"
BETTER_AUTH_URL="http://localhost:3000"

# ── App Public URL ────────────────────────────────────────────
# Used to construct public eBay image URLs: https://{domain}/uploads/{filename}
# Must be your VPS subdomain so eBay can reach images during local dev AND production.
# Example: https://magicalstaff.aigardens.life
NEXT_PUBLIC_APP_URL="https://magicalstaff.aigardens.life"

# ── Dev→VPS Image Mirroring ───────────────────────────────────
# Replaces the old ngrok tunnel. When developing locally, uploaded images are
# mirrored to the VPS at NEXT_PUBLIC_APP_URL/api/internal/mirror-upload so that
# eBay can fetch them at the public domain URL.
#
# Set the SAME random string on BOTH your local machine AND the VPS.
# Generate with: openssl rand -hex 32
#
# Local .env:  enables outgoing mirror requests after each upload
# VPS .env:    authorises incoming mirror requests from your local machine
# On VPS only (production): leave MIRROR_SECRET unset — mirroring is skipped
MIRROR_SECRET="generate-a-long-random-string-with-openssl-rand-hex-32"

# ── eBay OAuth ────────────────────────────────────────────────
# Get these from your eBay Developer account: https://developer.ebay.com
# EBAY_CLIENT_ID and EBAY_CLIENT_SECRET are your app's OAuth credentials.
# EBAY_REFRESH_TOKEN is the long-lived user token obtained after OAuth consent flow.
EBAY_CLIENT_ID="your_ebay_client_id"
EBAY_CLIENT_SECRET="your_ebay_client_secret"
EBAY_REFRESH_TOKEN="your_ebay_user_refresh_token"

# Target marketplace ID — leave as EBAY_US unless selling on another market
EBAY_MARKETPLACE_ID="EBAY_US"

# Merchant location key — a seller-defined identifier for your inventory location.
# Must match the key used in createInventoryLocation (one-time setup).
EBAY_MERCHANT_LOCATION_KEY="primary_warehouse"

# ── Google Gemini ─────────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/app/apikey
# Models in use:
#   Primary pipeline (Steps 1-3): gemini-2.5-flash
#   "Dig Deeper" re-analysis:     gemini-2.5-pro
GEMINI_API_KEY="your_gemini_api_key"

# ── Email (Resend) — Optional ─────────────────────────────────
# Not required for core functionality. Used for future email features.
# Get your API key at: https://resend.com
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="no-reply@yourdomain.com"
